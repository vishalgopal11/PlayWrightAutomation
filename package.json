{
  "name": "PlayWrightAutomation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "regression": "npx playwright test --config playwright.config.ts",
    "webTests": "npx playwright test --config playwright.config.ts --grep @Web",
    "APITests": "npx playwright test --config playwright.config.ts --grep @API",
    "SafariNewConfig": "npx playwright test --config playwright.config1.ts --project=safari",
    "cucumber": "npx cucumber-js --exit",
    "cucumber:login": "npx cucumber-js features/login.feature --exit",
    "cucumber:order": "npx cucumber-js features/placeOrder.feature --exit",
    "cucumber:error": "npx cucumber-js features/errorValidation.feature --exit",
    "cucumber:smoke": "npx cucumber-js --tags @Smoke --exit",
    "cucumber:regression": "npx cucumber-js --tags @Regression --exit",
    "cucumber:negative": "npx cucumber-js --tags @Negative --exit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "*",
    "@playwright/test": "^1.59.1",
    "allure-playwright": "^2.0.0-beta.15",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
