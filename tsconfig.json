{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "sourceMap": true,
    "noEmit": true
  },
  "include": [
    "tests/**/*.ts",
    "pageobjects/**/*.ts",
    "utils/**/*.ts",
    "features/**/*.ts",
    "config/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "pageobjects_ts",
    "utils_ts"
  ]
}
